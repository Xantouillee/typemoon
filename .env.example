# Supabase — powers accounts and the global leaderboard.
# Copy this file to `.env.local` (gitignored) and fill in your project's values,
# found in the Supabase dashboard under Project Settings → API.
#
# Both are safe to expose in a client bundle: the anon key only ever grants what
# your Row-Level-Security policies allow. Leave them blank and the app runs fine
# with the leaderboard switched off.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
